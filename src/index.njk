  <!-- FEATURES SECTION (open layout, no cards) -->
  <section id="why-tofupass" class="relative z-10 pt-16 pb-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-black mb-3 text-[#4A3728] dark:text-[#F0E6D8]">What makes <span class="brand-wordmark">Tofu<span class="brand-wordmark-accent">Pass</span></span> different?</h2>
        <p class="text-[#8B7355] dark:text-[#B8A890] text-base max-w-2xl mx-auto font-medium">A password generator built around real-world usability, trustworthy randomness, and patterns people can actually work with.</p>
      </div>
      <div class="features-open grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-10">

        <!-- Feature 1 -->
        <div class="feature-open text-center">
          <div class="feature-dot feature-dot-violet mx-auto mb-5" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="w-6 h-6">
              <rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" fill="none" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"></rect>
              <path d="M8 11V8a4 4 0 1 1 8 0v3" stroke="currentColor" fill="none" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3 class="text-lg font-extrabold mb-2 text-[#4A3728] dark:text-[#F0E6D8]">Security Without Theater</h3>
          <p class="text-[#8B7355] dark:text-[#B8A890] text-sm leading-relaxed">Uses the browser's <code class="text-[#6BBF59] font-mono text-xs font-bold">crypto.getRandomValues()</code> so the randomness is real, not decorative.</p>
        </div>

        <!-- Feature 2 -->
        <div class="feature-open text-center">
          <div class="feature-dot feature-dot-green mx-auto mb-5" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="w-6 h-6">
              <path d="M12 3l7 3v5c0 5-3.2 8.4-7 10-3.8-1.6-7-5-7-10V6l7-3z" stroke="currentColor" fill="none" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3 class="text-lg font-extrabold mb-2 text-[#4A3728] dark:text-[#F0E6D8]">Designed For Humans</h3>
          <p class="text-[#8B7355] dark:text-[#B8A890] text-sm leading-relaxed">Word-based passwords are easier to type and recall, which means less reuse, less simplification, and fewer sticky notes.</p>
        </div>

        <!-- Feature 3 -->
        <div class="feature-open text-center">
          <div class="feature-dot feature-dot-yellow mx-auto mb-5" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="w-6 h-6">
              <path d="M6 8.5c0-1.4 1.1-2.5 2.5-2.5h7c1.4 0 2.5 1.1 2.5 2.5v7c0 1.4-1.1 2.5-2.5 2.5h-7C7.1 18 6 16.9 6 15.5z" stroke="currentColor" fill="none" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M9 10h6" stroke="currentColor" fill="none" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M9 14h4" stroke="currentColor" fill="none" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3 class="text-lg font-extrabold mb-2 text-[#4A3728] dark:text-[#F0E6D8]">Clear, Consistent Patterns</h3>
          <p class="text-[#8B7355] dark:text-[#B8A890] text-sm leading-relaxed">Soft, Firm, and Extra Firm each follow predictable structures, so you always know what you're getting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION (flowing, no boxes) -->
  <section class="relative z-10 pb-24 px-4">
    <div class="max-w-2xl mx-auto text-center">

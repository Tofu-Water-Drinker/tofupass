  <!-- PHONETIC BOTTOM SHEET (overlay, doesn't push content) -->
  <div id="phoneticBackdrop" class="phonetic-backdrop" onclick="closePhoneticGuide()"></div>
  <aside id="phoneticDrawer" class="phonetic-sheet" aria-labelledby="phoneticTitle" aria-hidden="true">
    <div class="phonetic-sheet-head">
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-extrabold uppercase tracking-[0.12em] text-[#4A3728] dark:text-[#F0E6D8]">Phonetic Guide</span>
        <button onclick="closePhoneticGuide()" data-close class="phonetic-close" aria-label="Close phonetic guide">&times;</button>
      </div>
      <div id="phoneticPasswordEcho" class="phonetic-pw-echo font-mono text-lg font-bold text-[#6BBF59] break-all text-center mb-3"></div>
      <div class="flex gap-2">
        <button id="tabMilitary" class="tab-btn active" onclick="setPhoneticMode('military')" aria-selected="true" aria-label="Military NATO phonetic guide">
          <span class="ui-icon phonetic-label-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M5 11a7 7 0 0 1 14 0"></path>
              <path d="M7 11v2a5 5 0 0 0 10 0v-2"></path>
              <path d="M4 11h16"></path>
            </svg>
          </span>NATO
        </button>
        <button id="tabKid" class="tab-btn" onclick="setPhoneticMode('kid')" aria-selected="false" aria-label="Kid-friendly phonetic guide">

  <!-- GENERATOR (front and center) -->
  <main class="relative z-10 pt-24 pb-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <div class="hero-stage">

        <!-- GENERATOR CARD -->
        <div class="generator-shell mb-6">
        <div class="generator-card p-6 sm:p-8 relative">
          <!-- Mascot + tagline -->
          <div class="flex flex-col items-center mb-5">
            <a href="/miso/" class="mascot-wrap" aria-label="Meet Miso">
              <img id="generatorMascot" src="/tofu.png" alt="Miso the TofuPass mascot" class="mascot-squish w-24 h-24 sm:w-28 sm:h-28 mascot-glow" />
              <span id="mascotSparks" class="mascot-sparks" aria-hidden="true">
                <span class="mascot-spark mascot-spark-1"></span>
                <span class="mascot-spark mascot-spark-2"></span>
                <span class="mascot-spark mascot-spark-3"></span>
                <span class="mascot-spark mascot-spark-4"></span>
              </span>
              <span id="mascotBubble" class="mascot-bubble" aria-live="polite" aria-atomic="true"></span>
            </a>
            <p class="mt-3 text-xs font-bold uppercase tracking-[0.2em] text-[#8B7355]/50 dark:text-[#B8A890]/50">Tap to generate &nbsp;&middot;&nbsp; Click to copy</p>
          </div>

          <!-- Password Display -->
          <button type="button" onclick="copyPassword()" id="passwordPanel"
            class="password-panel w-full px-5 py-5 mb-5 min-h-[72px] flex flex-col items-center justify-center text-center">
            <p id="passwordDisplay" class="text-2xl sm:text-3xl font-bold text-center text-[#6BBF59] break-all leading-snug">
              Generating...
            </p>
            <span id="passwordHint" class="password-hint mt-3 text-[11px] font-bold uppercase tracking-[0.22em]">Click password to copy</span>
          </button>

          <!-- Action Buttons -->
          <div class="flex gap-3 flex-col sm:flex-row">
            <button id="generateBtn" onclick="generateNewPassword()"
              class="cta-btn flex-1 relative z-10 px-6 py-3 rounded-xl font-bold text-base text-white shadow-lg">
              Generate New Password
            </button>
            <button id="phoneticBtn" onclick="togglePhoneticGuide()" aria-expanded="false"
              class="flex-1 px-6 py-3 rounded-xl font-semibold text-sm transition-all">
              <span class="ui-icon phonetic-label-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M4 6h6"></path>
                  <path d="M4 10h10"></path>
                  <path d="M4 14h7"></path>
                  <path d="M15 6l5 5-5 5"></path>
                </svg>
              </span>Phonetic Guide
            </button>
          </div>
        </div>
        </div>

        <!-- LEVEL SELECTOR CARDS -->
        <div class="firmness-grid grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">

        <!-- Soft -->
        <div class="level-card p-5 text-left"
          id="card-soft" onclick="selectLevel('soft')">
          <div class="ui-icon level-icon icon-soft" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M12 12c0-3-2-5-4-5-1.7 0-3 1.3-3 3 0 2 2 4 7 7"></path>
              <path d="M12 12c0-3 2-5 4-5 1.7 0 3 1.3 3 3 0 2-2 4-7 7"></path>
              <circle cx="12" cy="12" r="1.5"></circle>
            </svg>
          </div>
          <div class="text-xs font-extrabold tracking-widest text-[#FF7A7A] uppercase mb-1">Soft</div>
          <div class="font-extrabold text-[#4A3728] dark:text-[#F0E6D8] text-base mb-1">Simple & Sweet</div>
          <p class="text-xs text-[#8B7355] dark:text-[#B8A890] leading-relaxed">word + word + number<br/>e.g. <span class="text-[#4A3728] dark:text-[#F0E6D8] font-mono font-bold">happykoala72</span></p>
        </div>

        <!-- Firm -->
        <div class="level-card p-5 text-left active-firm"
          id="card-firm" onclick="selectLevel('firm')">
          <div class="ui-icon level-icon icon-firm" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M12 3l7 3v5c0 5-3.2 8.4-7 10-3.8-1.6-7-5-7-10V6l7-3z"></path>
            </svg>
          </div>
          <div class="flex items-center gap-2 mb-1">
            <div class="text-xs font-extrabold tracking-widest text-[#6BBF59] uppercase">Firm</div>
            <span class="text-xs text-[#6BBF59] font-bold">Recommended</span>
          </div>
          <div class="font-extrabold text-[#4A3728] dark:text-[#F0E6D8] text-base mb-1">Strong & Usable</div>
          <p class="text-xs text-[#8B7355] dark:text-[#B8A890] leading-relaxed">symbol + Word + Word + number<br/>e.g. <span class="text-[#4A3728] dark:text-[#F0E6D8] font-mono font-bold">!DancingKoala73</span></p>
        </div>

        <!-- Extra Firm -->
        <div class="level-card p-5 text-left"
          id="card-extra" onclick="selectLevel('extra')">
          <div class="ui-icon level-icon icon-extra" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <rect x="4" y="5" width="16" height="4" rx="1.5"></rect>
              <rect x="4" y="10" width="16" height="4" rx="1.5"></rect>
              <rect x="4" y="15" width="16" height="4" rx="1.5"></rect>
            </svg>
          </div>
          <div class="text-xs font-extrabold tracking-widest text-[#E6A800] uppercase mb-1">Extra Firm</div>
          <div class="font-extrabold text-[#4A3728] dark:text-[#F0E6D8] text-base mb-1">Passphrase Power</div>
          <p class="text-xs text-[#8B7355] dark:text-[#B8A890] leading-relaxed">word-word-word-word<br/>e.g. <span class="text-[#4A3728] dark:text-[#F0E6D8] font-mono font-bold">bloom-tiger-leaf-fog</span></p>
        </div>

        </div>

        <p class="text-xs text-[#8B7355]/60 dark:text-[#B8A890]/60 mt-3 font-semibold">Built for the sweet spot between security and usability, with all generation staying on your device.</p>

        <a href="#why-tofupass" class="scroll-cue" aria-label="Scroll down to learn more">
          <span class="scroll-cue-icon ui-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M12 5v14"></path>
              <path d="m6 13 6 6 6-6"></path>
            </svg>
          </span>
        </a>
      </div>
    </div>

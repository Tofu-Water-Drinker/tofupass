        <svg class="w-48 h-4 text-[#8BC34A]/20" viewBox="0 0 200 16" fill="none" aria-hidden="true">
          <path d="M0 8 C 25 0, 50 16, 75 8 S 125 0, 150 8 S 175 16, 200 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
